    ],
    "B": [
      {
        "bar_start": 8.9,
        "bar_end": 11.3,
        "text": "All the pretty girls in the foreground with my mind"
      },
      {
        "bar_start": 11.3,
        "bar_end": 16.4,
        "text": "I thought I'd done enough but they keep moving the line"
      },
      {
        "bar_start": 16.4,
        "bar_end": 23.4,
        "text": "I thought I found the antidote this time"
      },
      {
        "bar_start": 23.4,
        "bar_end": 27.2,
        "text": "All the nights I spent fighting bad thoughts in my room"
      },
      {
        "bar_start": 27.2,
        "bar_end": 31,
        "text": "Feeling so alone might as well be on the moon"
      },
      {
        "bar_start": 31,
        "bar_end": 39.3,
        "text": "I thought I found the antidote with you"
      },
      {
        "bar_start": 39.3,
        "bar_end": 44.2,
        "text": "This fool of poison in my heart is full of doubt"
      },
      {
        "bar_start": 44.2,
        "bar_end": 48.4,
        "text": "I got toxins in my bloodstream you tried hard to suck them out"
      },
      {
        "bar_start": 48.4,
        "bar_end": 51.4,
        "text": "And it feels like medication and it's good for me"
      },
      {
        "bar_start": 51.4,
        "bar_end": 55.6,
        "text": "I'm sure but it don't matter how your love feels anymore"
      },
      {
        "bar_start": 55.6,
        "bar_end": 57.4,
        "text": "It'll never be cured"
      },
      {
        "bar_start": 57.4,
        "bar_end": 61.4,
        "text": "It'll never be cured"
      },
      {
        "bar_start": 61.4,
        "bar_end": 67,
